# Keep Vercel (frontend build) from seeing the Python backend.
# Patterns are ANCHORED to repo root with a leading slash so they
# never match anything under src/ (e.g. src/services/ stays included).

/backend/
/requirements.txt
/engine/
/models/
/routers/
/utils/
/__pycache__/
/.venv/
/venv/

# stray root-level python files (NOT anything under src/)
/server.py
/*.py
